# Server
SERVER_PORT=3000
NODE_ENV=development

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=agenthub

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=agent_hub_app
JWT_EXPIRES_IN=7d

# Agent runtime
# 进程重启时清理上个进程残留的活跃 turn 指针（单实例安全）。
# 多实例部署须设为 false，避免清掉其它实例正在跑的 turn，改由活跃指针安全 TTL 兜底。
AGENT_RECLAIM_ON_BOOT=true
# 单轮 agent 最大运行时间；超时会 abort 并向订阅端发送 error + done。
AGENT_TURN_TIMEOUT_MS=1800000
